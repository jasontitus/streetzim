From b8e10fd57bb862a0773c4fec697b69945087ee76 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Sat, 14 Mar 2026 08:42:54 +0000
Subject: [PATCH] Replace spin-loop polling with condition variables to fix
 threading hangs

The writer pipeline used microsleep-based spin loops for all thread
synchronization (taskRunner, clusterWriter, queue backpressure, and
task completion waiting). With slow compression (e.g. zstd level 22),
these spin loops wasted CPU cycles and could cause thread starvation,
leading to hangs when building large ZIM files.

Replace all four spin-loop sites with proper std::condition_variable
waits:
- Queue: CV-based blocking for push backpressure and pop notification
- taskRunner: blocks on queue CV until a task is available
- clusterWriter: blocks on dedicated CV until head cluster is closed
- TrackableTask::waitNoMoreTask: blocks on CV until task count reaches 0

Also fix meson.build icu dependency syntax (required:false as keyword).

https://claude.ai/code/session_016EngQrr9sZrAtYxKKnD6eP
---
 meson.build                  |  6 ++--
 src/writer/clusterWorker.cpp |  1 +
 src/writer/creator.cpp       | 13 ++++++--
 src/writer/creatordata.h     |  3 ++
 src/writer/queue.h           | 60 +++++++++++++++++++++++-------------
 src/writer/workers.cpp       | 60 ++++++++++++++++++++----------------
 src/writer/workers.h         | 33 ++++++++++++++------
 7 files changed, 112 insertions(+), 64 deletions(-)

diff --git a/meson.build b/meson.build
index bce9c2f..1540769 100644
--- a/meson.build
+++ b/meson.build
@@ -80,9 +80,9 @@ if xapian_dep.found()
         icu_dep = [icu_dep, dependency('icu-uc', static:static_linkage)]
     endif
 else
-    icu_dep = dependency('icu-i18n', 'required:false', static:static_linkage)
-    if icu_dep.version().version_compare('>= 76')
-        icu_dep = [icu_dep, dependency('icu-uc', 'required:false', static:static_linkage)]
+    icu_dep = dependency('icu-i18n', required:false, static:static_linkage)
+    if icu_dep.found() and icu_dep.version().version_compare('>= 76')
+        icu_dep = [icu_dep, dependency('icu-uc', required:false, static:static_linkage)]
     endif
 endif
 
diff --git a/src/writer/clusterWorker.cpp b/src/writer/clusterWorker.cpp
index c10e5b0..f2744e0 100644
--- a/src/writer/clusterWorker.cpp
+++ b/src/writer/clusterWorker.cpp
@@ -28,6 +28,7 @@ namespace zim
 
     void ClusterTask::run(CreatorData* data) {
       cluster->close();
+      data->m_clusterClosedCV.notify_one();
     };
 
   }
diff --git a/src/writer/creator.cpp b/src/writer/creator.cpp
index 707f71f..1eca57e 100644
--- a/src/writer/creator.cpp
+++ b/src/writer/creator.cpp
@@ -492,10 +492,16 @@ namespace zim
 
     void CreatorData::addError(const std::exception_ptr exception)
     {
-      std::lock_guard<std::mutex> l(m_exceptionLock);
-      if (!m_exceptionSlot) {
-        m_exceptionSlot = exception;
+      {
+        std::lock_guard<std::mutex> l(m_exceptionLock);
+        if (!m_exceptionSlot) {
+          m_exceptionSlot = exception;
+        }
       }
+      // Wake up any threads that might be blocked waiting on CVs
+      m_clusterClosedCV.notify_all();
+      taskList.notifyWaiters();
+      clusterToWrite.notifyWaiters();
     }
 
     bool CreatorData::isErrored() const
@@ -523,6 +529,7 @@ namespace zim
       // Wait for writerThread to finish.
       if (writerThread.joinable()) {
         clusterToWrite.pushToQueue(nullptr);
+        m_clusterClosedCV.notify_one();
         writerThread.join();
       }
     }
diff --git a/src/writer/creatordata.h b/src/writer/creatordata.h
index 987bc83..79420e7 100644
--- a/src/writer/creatordata.h
+++ b/src/writer/creatordata.h
@@ -32,6 +32,7 @@
 #include <map>
